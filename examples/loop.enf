extern fun putchar(c int) int;
fun print_int_h(i int) nret {
    if i > 9 {
        print_int_h(i / 10);
    }
    val remainder = i % 10;
    putchar(remainder + 48);
}

fun print_int(i int) nret {
    if i == 0 {
        putchar(48);
    } else {
        print_int_h(i);
    }
    putchar(10);
}

fun main() nret {
    var i = 0;
    whl i < 10 {
        print_int(i);
        i = i + 1;
    }
}
